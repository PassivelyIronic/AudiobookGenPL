# ============================================================
#  Audio-Książnica - przykładowa konfiguracja
#  Skopiuj do `.env` w katalogu głównym i dostosuj wartości.
# ============================================================

# --- Redis / Celery ---------------------------------------------------------
AK_REDIS_URL=redis://localhost:6379/0
AK_CELERY_TASK_TIME_LIMIT_SEC=21600        # 6 godzin
AK_CELERY_RESULT_TTL_SEC=86400             # 24 godziny

# --- Składnica plików -------------------------------------------------------
AK_UPLOAD_DIR=./storage/uploads
AK_OUTPUT_DIR=./storage/outputs
AK_WORK_DIR=./storage/work
AK_CLEANUP_UPLOAD_AFTER_SUCCESS=true
AK_CLEANUP_WORK_DIR_AFTER_SUCCESS=true

# --- TTS --------------------------------------------------------------------
# mock_mode=true generuje atrapy WAV (sinus) - dobre do developmentu/CI.
# Ustaw false dopiero po odkomentowaniu TTS/torch w requirements.txt.
AK_TTS_MOCK_MODE=true
AK_TTS_LANGUAGE=pl
AK_TTS_DEVICE=cuda                          # albo "cpu"
# AK_TTS_SPEAKER_WAV=/data/voices/lektor.wav   # wymagane przy mock_mode=false

# --- Chunker ----------------------------------------------------------------
AK_CHUNK_MAX_CHARS=500

# --- Stitcher (MP3) ---------------------------------------------------------
AK_MP3_BITRATE=192k
AK_MP3_SAMPLE_RATE=24000

# --- API --------------------------------------------------------------------
AK_MAX_UPLOAD_SIZE_MB=100
