# ============================================================
#  Audio-Książnica - przykładowa konfiguracja
#  Skopiuj do `.env` w katalogu głównym i dostosuj wartości.
# ============================================================

# --- Redis / Celery ---------------------------------------------------------
EN_REDIS_URL=redis://localhost:6379/0
EN_CELERY_TASK_TIME_LIMIT_SEC=21600        # 6 godzin
EN_CELERY_RESULT_TTL_SEC=86400             # 24 godziny

# --- Składnica plików -------------------------------------------------------
EN_UPLOAD_DIR=./storage/uploads
EN_OUTPUT_DIR=./storage/outputs
EN_WORK_DIR=./storage/work
EN_CLEANUP_UPLOAD_AFTER_SUCCESS=true
EN_CLEANUP_WORK_DIR_AFTER_SUCCESS=true

# --- TTS --------------------------------------------------------------------
# mock_mode=true generuje atrapy WAV (sinus) - dobre do developmentu/CI.
# Ustaw false dopiero po odkomentowaniu TTS/torch w requirements.txt.
EN_TTS_MOCK_MODE=true
EN_TTS_LANGUAGE=pl
EN_TTS_DEVICE=cuda                          # albo "cpu"
# EN_TTS_SPEAKER_WAV=/data/voices/lektor.wav   # wymagane przy mock_mode=false

# --- Chunker ----------------------------------------------------------------
EN_CHUNK_MAX_CHARS=500

# --- Stitcher (MP3) ---------------------------------------------------------
EN_MP3_BITRATE=192k
EN_MP3_SAMPLE_RATE=24000

# --- API --------------------------------------------------------------------
EN_MAX_UPLOAD_SIZE_MB=100
